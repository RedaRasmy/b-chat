    "main": "index.js",
    "scripts": {
        "dev:client": "pnpm --filter @bchat/client dev",
        "dev:server": "pnpm --filter @bchat/server dev",
        "dev": "pnpm --parallel --filter @bchat/client --filter @bchat/server dev",
        "build": "pnpm --filter @bchat/client build",
        "start": "pnpm --filter @bchat/server start",
        "db:push": "pnpm --filter=@bchat/database push",
        "db:generate": "nnpm --filter=@bchat/database generate",
        "db:migrate": "pnpm --filter=@bchat/database migrate",
        "db:studio": "pnpm --filter=@bchat/database studio",
        "db:seed": "pnpm --filter=@bchat/database seed",
        "cloc": "cloc . --exclude-dir=node_modules,ui",
        "cloc:ts": "cloc . --exclude-dir=node_modules,ui --include-lang=TypeScript"
    },
